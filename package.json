{
  "name": "renovation-twin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @renovation-twin/web dev",
    "build": "pnpm --filter @renovation-twin/web build",
    "lint": "pnpm --filter @renovation-twin/web lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @renovation-twin/db generate",
    "db:push": "pnpm --filter @renovation-twin/db exec prisma db push",
    "db:studio": "pnpm --filter @renovation-twin/db exec prisma studio",
    "db:validate": "pnpm --filter @renovation-twin/db exec prisma validate",
    "supabase:db:push": "supabase db push",
    "supabase:db:lint": "supabase db lint --local --fail-on warning",
    "supabase:status": "supabase status"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
